# n8n MCP Server Configuration
# Copy this file to .env and fill in your values

# n8n instance URL (without /webhook suffix)
N8N_API_URL=https://n8n.cosmisk.ai

# n8n API key - generate from n8n Settings > API
N8N_API_KEY=

# MCP server mode (stdio for Claude Desktop/Code integration)
MCP_MODE=stdio

# Log level: error, warn, info, debug
LOG_LEVEL=error

# Disable console output for clean MCP communication
DISABLE_CONSOLE_OUTPUT=true

# Webhook security mode: strict (default) or moderate (for local n8n)
# WEBHOOK_SECURITY_MODE=moderate
